NODE_ENV=development
APP_ENV=local
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Madrid
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/radar_vpo
JWT_ACCESS_SECRET=replace-with-long-secret
JWT_REFRESH_SECRET=replace-with-long-secret-2
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
JOB_TIMEZONE=Europe/Madrid
CRON_CHECK_PROMOTIONS=*/30 * * * *
CRON_PROCESS_PDFS=*/30 * * * *
CRON_ANALYZE_PROMOTIONS=0 * * * *
CRON_REPAIR_DOCUMENT_LINKS=0 */4 * * *
CRON_REANALYZE_STALE_PDFS=30 */6 * * *
CRON_PUBLISH_PROMOTIONS=15 * * * *
CRON_SEND_REMINDERS=0 8 * * *
CRON_FETCH_DAILY_NEWS=0 6 * * *
CRON_PUBLISH_EDUCATIONAL_POST=0 7 * * *

# AI provider fallback order: openai,azure-openai,anthropic
AI_PROVIDER_ORDER=openai,azure-openai,anthropic
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000

OPENAI_API_KEY=
OPEN_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OCRSPACE_API_KEY=
OCRSPACE_LANGUAGE=spa

NEWS_ENABLED=true
EDUCATIONAL_ENABLED=true
DAILY_NEWS_MAX_ITEMS=5
NEWS_RSS_FEEDS=https://www.gencat.cat/feeds/premsa.xml,https://ajuntament.barcelona.cat/rss.xml

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_ID_PRO=

S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_REGION=auto
S3_FORCE_PATH_STYLE=false

REGISTRE_NEWS_URL=https://www.registresolicitants.cat/registre/noticias/03_noticias.jsp
REGISTRE_MIN_YEAR=2026
REGISTRE_MAX_PAGES=3
