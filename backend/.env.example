NODE_ENV=development
APP_ENV=local
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Madrid
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/radar_vpo
JWT_ACCESS_SECRET=generate-a-unique-64-character-access-secret-before-running
JWT_REFRESH_SECRET=generate-a-different-64-character-refresh-secret-before-running
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
SEED_SAMPLE_DATA=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
JOB_TIMEZONE=Europe/Madrid
CRON_CHECK_PROMOTIONS=*/30 * * * *
CRON_PROCESS_PDFS=*/30 * * * *
CRON_ANALYZE_PROMOTIONS=0 * * * *
CRON_REPAIR_DOCUMENT_LINKS=0 */4 * * *
CRON_REANALYZE_STALE_PDFS=30 */6 * * *
CRON_PUBLISH_PROMOTIONS=15 * * * *
CRON_SEND_REMINDERS=0 8 * * *
CRON_FETCH_DAILY_NEWS=0 6 * * *
CRON_PUBLISH_EDUCATIONAL_POST=0 7 * * *

# AI provider fallback order: openai,azure-openai,anthropic
AI_PROVIDER_ORDER=openai,azure-openai,anthropic
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000

OPENAI_API_KEY=
OPEN_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OCRSPACE_API_KEY=
OCRSPACE_LANGUAGE=spa

NEWS_ENABLED=true
EDUCATIONAL_ENABLED=true
DAILY_NEWS_MAX_ITEMS=5
NEWS_RSS_FEEDS=https://www.gencat.cat/feeds/premsa.xml,https://ajuntament.barcelona.cat/rss.xml

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_ID_PRO=
BREVO_API_KEY=
BREVO_SMS_SENDER=RadarVPO
BREVO_EMAIL_SENDER=Radar VPO <info@radarvpo.com>
BREVO_PRO_ALERTS_ENABLED=false

# Amazon S3 file storage. Use AWS_* for real AWS S3. Legacy S3_* aliases are still supported.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
MAX_FILE_SIZE_BYTES=26214400
PROMOTION_ASSET_MAX_SIZE_BYTES=26214400
COURSE_ASSET_MAX_SIZE_BYTES=524288000
COURSE_COVER_MAX_SIZE_BYTES=5242880
S3_SIGNED_URL_TTL_SECONDS=900
ALLOWED_FILE_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,video/mp4,video/quicktime

# Backward-compatible aliases for S3-compatible providers.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_REGION=auto
S3_FORCE_PATH_STYLE=false

REGISTRE_NEWS_URL=https://www.registresolicitants.cat/registre/noticias/03_noticias.jsp
REGISTRE_MIN_YEAR=2026
REGISTRE_MAX_PAGES=3
NEWS_CACHE_TTL_SECONDS=60
ALERTS_CACHE_TTL_SECONDS=30

# Frontend public runtime variables. These are safe to expose to the browser.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Public API base used for stable course cover URLs (set to production API URL on Railway).
PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=true
NEXT_PUBLIC_STRIPE_PRO_LINK=
